{
  "name": "weixin-symbio-bridge",
  "version": "0.1.0",
  "description": "Standalone WeChat iLink bridge for Symbio and OpenClaw-like local agents.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "weixin-symbio": "./dist/cli.js"
  },
